{
  "manifest_version": 3,
  "name": "LinkedIn Headshot Poster",
  "version": "1.0",
  "description": "Post headshots to LinkedIn via Publer — select images and post with one click",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://app.publer.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
